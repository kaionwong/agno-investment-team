# Required
# Ollama - Make sure Ollama is running with llama3.2 model
OLLAMA_BASE_URL="http://localhost:11434"

# Exa API for web search
EXA_API_KEY="***"

# Optional
# PARALLEL_API_KEY=***
# RUNTIME_ENV=dev

# Database Configuration
# Defaults work out of the box. Uncomment and update to use external PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai

# Database Credentials (REQUIRED if using external PostgreSQL)
# Update these values based on your populated environment variables
# DB_HOST=<your_postgres_host>
# DB_PORT=<your_postgres_port>
# DB_USER=<your_postgres_user>
# DB_PASS=<your_postgres_password>
# DB_DATABASE=<your_postgres_database>

# Ollama Configuration
# Notes:
# 1. Ensure Ollama is running: ollama serve
# 2. Ensure llama3.2 model is pulled: ollama pull llama3.2
# 3. Ensure nomic-embed-text model is available for embeddings: ollama pull nomic-embed-text
